#!/bin/bash

USAGE="Usage: sprite [-c] curryfile"

COMPILEONLY=0
while getopts "ch" OPTION
do
  case $OPTION in
    h)
      echo "$USAGE"
      exit 0
      ;;
    c)
      COMPILEONLY=1
      ;;
    ?)
      echo "$USAGE"
      exit 1
      ;;
  esac
done

shift $(($OPTIND - 1))

if [ "$#" != "1" ]; then
  echo "$USAGE"
  exit 1
fi

if [ -z "${SPRITE_HOME:-}" ]; then
  SPRITE_HOME=`(cd "\`dirname \"$0\"\`" > /dev/null ; cd ..; pwd)`
fi
export SPRITE_HOME

if [ -n "$CURRYPATH" ]; then
  CURRYPATH="$SPRITE_HOME/lib:$CURRYPATH"
else
  CURRYPATH="$SPRITE_HOME/lib"
fi
export CURRYPATH

trap "exit 1" ERR

# 1. Parse the curry module (and all dependent modules)
parsecurry --flat $1

# 2. Generate the makefile
mkdir -p .sprite
cat > .sprite/makefile <<EOF
MODULES := $1
MAIN_MODULE := $1
EXE := $1

include \$(SPRITE_HOME)/config/makefile

EOF

# 3. Build
cd .sprite
if [ "$COMPILEONLY" -eq 0 ]; then
  # Compile the executable.
  $SPRITE_HOME/config/makecmd
  mv $1 ..
else
  # Compile objects only.
  $SPRITE_HOME/config/makecmd objects
fi
cd ..

# 4. Execute
if [ "$COMPILEONLY" -eq 0 ]; then
  ./$1
fi

