#!/bin/bash

set -e

usage() {
  echo "Usage: sprite [-c|h|r] curryfile"
  echo "    -c  Compile the file as a module"
  echo "    -h  Display this help message"
  echo "    -r  Rebuild from scratch"
}

COMPILEONLY=0
REBUILD=0
while getopts "chr" OPTION
do
  case $OPTION in
    h)
      usage
      exit 0
      ;;
    c)
      COMPILEONLY=1
      ;;
    r)
      REBUILD=1
      ;;
    ?)
      usage
      exit 1
      ;;
  esac
done

shift $(($OPTIND - 1))

if [ "$#" != "1" ]; then
  usage
  exit 1
fi

if [ -z "${SPRITE_HOME:-}" ]; then
  SPRITE_HOME=`(cd "\`dirname \"$0\"\`" > /dev/null ; cd ..; pwd)`
fi
export SPRITE_HOME

if [ -n "$CURRYPATH" ]; then
  CURRYPATH="$SPRITE_HOME/lib:$CURRYPATH"
else
  CURRYPATH="$SPRITE_HOME/lib"
fi
export CURRYPATH

trap "exit 1" ERR

# 0. Clean if rebuilding
if [ "$REBUILD" -eq 1 ]; then
  rm -rf .curry .sprite
fi

# 1. Parse the curry module (and all dependent modules)
parsecurry --flat $1

# 2. Generate the makefile
mkdir -p .sprite
cat > .sprite/makefile <<EOF
MODULES := $1
MAIN_MODULE := $1
EXE := $1

include \$(SPRITE_HOME)/config/makefile

EOF

# Work around an annoying clock skew warning when working over NFS.
sleep 1

# 3. Build
cd .sprite
if [ "$COMPILEONLY" -eq 0 ]; then
  # Compile the executable.
  $SPRITE_HOME/config/makecmd
  mv $1 ..
else
  # Create the headers only.
  $SPRITE_HOME/config/makecmd modules
fi
cd ..

# 4. Execute
if [ "$COMPILEONLY" -eq 0 ]; then
  ./$1
fi

